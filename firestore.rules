rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['id', 'name', 'xp', 'level', 'badges', 'completedChallenges'])
          && data.keys().size() <= 9
          && data.id is string
          && data.name is string && data.name.size() <= 100
          && (data.get('photoURL', '') is string)
          && data.xp is number && data.xp >= 0
          && data.level is number && data.level > 0
          && data.badges is list && data.badges.size() <= 100
          && data.completedChallenges is list && data.completedChallenges.size() <= 500
          && (data.get('streak', 0) is number)
          && (data.get('lastActiveDate', '') is string);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['id', 'author', 'authorId', 'title', 'content', 'likes', 'replies', 'createdAt'])
          && data.id is string
          && data.author is string && data.author.size() <= 100
          && data.authorId is string && data.authorId == request.auth.uid
          && data.title is string && data.title.size() <= 200
          && data.content is string && data.content.size() <= 5000
          && data.likes is number && data.likes >= 0
          && data.replies is number && data.replies >= 0
          && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if true; 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }
    
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPost(incoming()) && incoming().createdAt == request.time;
      allow update: if isAuthenticated() && incoming().diff(resource.data).affectedKeys().hasOnly(['likes', 'replies']);
    }
    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }
    match /challenges/{challengeId} {
      allow read: if true;
      allow create, update: if true;
    }
  }
}
